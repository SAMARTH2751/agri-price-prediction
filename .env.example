# .env.example
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore

# ============================================
# API Configuration
# ============================================
AGMARKET_API_KEY=your_api_key_here
AGMARKET_API_URL=https://api.agmarket.gov.in/v1

# ============================================
# Model Configuration
# ============================================
MODEL_TYPE=lstm  # Options: xgboost, random_forest, lstm, arima
FORECAST_DAYS=30
CONFIDENCE_LEVEL=0.95
MODEL_DIR=models

# ============================================
# Data Configuration
# ============================================
DATA_SOURCE=synthetic  # Options: api, synthetic, csv
DATA_CACHE_DIR=data/cached
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed

# ============================================
# Database Configuration (if using)
# ============================================
DB_TYPE=sqlite  # Options: sqlite, postgresql, mysql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=agri_price_prediction
DB_POOL_SIZE=10

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_DIR=logs
LOG_FILE=app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================
# Application Configuration
# ============================================
APP_NAME=Agricultural Price Prediction System
APP_VERSION=1.0.0
DEBUG_MODE=False
SECRET_KEY=your_secret_key_change_in_production

# ============================================
# Streamlit Configuration
# ============================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=false
STREAMLIT_LOGGER_LEVEL=info

# ============================================
# AWS Configuration (if deploying to AWS)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=agri-price-prediction

# ============================================
# Email Configuration (if sending alerts)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=alerts@example.com

# ============================================
# Feature Flags
# ============================================
ENABLE_EMAIL_ALERTS=false
ENABLE_API_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_MODEL_CACHING=true

# ============================================
# Model Parameters (Advanced)
# ============================================
RANDOM_FOREST_N_ESTIMATORS=100
RANDOM_FOREST_MAX_DEPTH=20
XGBOOST_N_ESTIMATORS=100
XGBOOST_LEARNING_RATE=0.1
LSTM_EPOCHS=50
LSTM_BATCH_SIZE=32
LSTM_SEQUENCE_LENGTH=30

# ============================================
# ARIMA Parameters
# ============================================
ARIMA_ORDER_P=1
ARIMA_ORDER_D=1
ARIMA_ORDER_Q=1

# ============================================
# Prediction Settings
# ============================================
MIN_FORECAST_DAYS=7
MAX_FORECAST_DAYS=90
DEFAULT_FORECAST_DAYS=30

# ============================================
# Performance Thresholds
# ============================================
RMSE_THRESHOLD=200
MAPE_THRESHOLD=6.0
MIN_R2_SCORE=0.85

# ============================================
# Cache Settings
# ============================================
CACHE_ENABLED=true
CACHE_TTL=3600  # Time to live in seconds
MAX_CACHE_SIZE=1000  # MB

# ============================================
# Testing Configuration
# ============================================
TEST_DATA_SIZE=100
TEST_RANDOM_SEED=42
ENABLE_INTEGRATION_TESTS=true
